# Copy to .env for local dev. Never commit .env.

PORT=3000
LOG_LEVEL=debug
DATABASE_URL=./gridsight.db

# Optional: when set, /v1/assets/:id/recommendations routes through OpenRouter.
# Lets users pick between Claude Sonnet/Opus and OpenAI GPT models without
# wiring per-vendor SDKs. When unset (the public demo case), the endpoint
# serves hand-authored fixtures from src/domain/fixtures/recommendations/.
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_DEFAULT_MODEL=anthropic/claude-sonnet-4.5

# CORS origin for the Angular dev server
CORS_ORIGIN=http://localhost:4200
