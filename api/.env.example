# Copy to .env for local dev. Never commit .env.

PORT=3000
LOG_LEVEL=debug
DATABASE_URL=./gridsight.db

# Optional: when set, /v1/assets/:id/recommendations calls Claude directly.
# When unset (the public demo case), the endpoint serves hand-authored fixtures
# from src/domain/fixtures/recommendations/.
# ANTHROPIC_API_KEY=sk-ant-...

# CORS origin for the Angular dev server
CORS_ORIGIN=http://localhost:4200
